# Phenotype-journeys observability — env vars
# Set OTEL_EXPORTER_OTLP_ENDPOINT to a running otel/opentelemetry-collector-contrib
# instance. The default below assumes the standard local Docker-compose stack:
#   docker run --rm -p 4317:4317 -p 4318:4318 \
#     -v $(pwd)/ops/otel/collector-config.yaml:/etc/otelcol-contrib/config.yaml \
#     otel/opentelemetry-collector-contrib:0.96.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=phenotype-journey
OTEL_RESOURCE_ATTRIBUTES=service.namespace=phenotype-journeys,deployment.environment=local
RUST_LOG=info,phenotype_journey=debug,phenotype_journey_core=debug