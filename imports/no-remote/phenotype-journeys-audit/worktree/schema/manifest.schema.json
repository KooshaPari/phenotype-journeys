{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kooshapari.com/schemas/journey-manifest.schema.json",
  "title": "Manifest",
  "description": "Phenotype journey manifest. Generated by phenotype-journey-core; the canonical source of truth is `phenotype_journey_core::manifest_schema()`.",
  "type": "object",
  "required": ["id", "intent"],
  "properties": {
    "id": { "type": "string" },
    "intent": { "type": "string" },
    "recording": { "type": ["string", "null"] },
    "recording_gif": { "type": ["string", "null"] },
    "keyframe_count": { "type": "integer", "minimum": 0, "default": 0 },
    "passed": { "type": "boolean", "default": false },
    "steps": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/Step" }
    },
    "verification": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/Verification" }]
    }
  },
  "$defs": {
    "Step": {
      "type": "object",
      "required": ["index", "slug", "intent", "screenshot_path"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "slug": { "type": "string" },
        "intent": { "type": "string" },
        "screenshot_path": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "judge_score": { "type": ["number", "null"] },
        "assertions": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/StepAssertions" }]
        },
        "annotations": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/Annotation" }
            }
          ]
        }
      }
    },
    "Annotation": {
      "type": "object",
      "description": "Bounding-box annotation overlaid on a step keyframe. Coordinates are in source image pixels (top-left origin).",
      "required": ["bbox", "label"],
      "properties": {
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "integer", "minimum": 0 },
          "description": "[x, y, width, height] in source image pixels."
        },
        "label": { "type": "string" },
        "color": { "type": ["string", "null"] },
        "style": { "type": "string", "enum": ["solid", "dashed"], "default": "solid" },
        "note": { "type": ["string", "null"] },
        "kind": {
          "type": "string",
          "enum": ["region", "pointer", "highlight"],
          "default": "region"
        }
      },
      "additionalProperties": false
    },
    "StepAssertions": {
      "type": "object",
      "description": "Optional ground-truth assertions applied to a step's keyframe via OCR.",
      "properties": {
        "must_contain": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "must_not_contain": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "expected_exit": {
          "type": ["integer", "null"],
          "description": "If set, the LAST keyframe of the journey must contain `__EXIT_<N>__`."
        },
        "ocr_required": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "Verification": {
      "type": "object",
      "required": [
        "overall_score",
        "describe_confidence",
        "judge_confidence",
        "all_intents_passed",
        "mode",
        "timestamp"
      ],
      "properties": {
        "overall_score": { "type": "number" },
        "describe_confidence": { "type": "number" },
        "judge_confidence": { "type": "number" },
        "all_intents_passed": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["mock", "api"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "assertion_violations": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/Violation" }
        }
      }
    },
    "Violation": {
      "type": "object",
      "required": ["step_index", "kind", "expected", "got_snippet"],
      "properties": {
        "step_index": { "type": "integer", "minimum": 0 },
        "kind": { "type": "string", "enum": ["MustContain", "MustNotContain", "ExitCode"] },
        "expected": { "type": "string" },
        "got_snippet": { "type": "string" }
      }
    }
  }
}
